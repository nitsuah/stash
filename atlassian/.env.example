# ── Jira + Confluence (same Atlassian account credentials) ───────────────────
JIRA_HOST=https://yourorg.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_TOKEN=your_atlassian_api_token_here

# ── Bitbucket Cloud ──────────────────────────────────────────────────────────
# App password: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_WORKSPACE=your_workspace_slug
BITBUCKET_USERNAME=you@example.com
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password

# ── Statuspage ───────────────────────────────────────────────────────────────
# API key: https://manage.statuspage.io/login → API → API keys
STATUSPAGE_API_KEY=your_statuspage_api_key
STATUSPAGE_PAGE_ID=your_page_id
