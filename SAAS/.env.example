# ── PagerDuty ────────────────────────────────────────────────────────────────
# API key: app.pagerduty.com → Integrations → API Access Keys
PAGERDUTY_API_KEY=your_pagerduty_api_key
# Routing key for Events API v2 (service integration key)
PAGERDUTY_ROUTING_KEY=your_32char_integration_key
# Default service ID for incident examples (Services → select service → copy ID from URL)
PAGERDUTY_SERVICE_ID=your_service_id
# Default escalation policy ID
PAGERDUTY_ESCALATION_POLICY_ID=your_escalation_policy_id

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token: github.com → Settings → Developer settings → PAT
GITHUB_TOKEN=ghp_your_token
# Default repo and org for examples (owner/repo format)
GITHUB_REPO=owner/repo
GITHUB_ORG=your-org

# ── Datadog ───────────────────────────────────────────────────────────────────
# API key: app.datadoghq.com → Organization Settings → API Keys
DATADOG_API_KEY=your_datadog_api_key
# App key: app.datadoghq.com → Organization Settings → Application Keys
DATADOG_APP_KEY=your_datadog_app_key
# Site (default: datadoghq.com — use datadoghq.eu for EU)
DATADOG_SITE=datadoghq.com

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token: api.slack.com → Your Apps → OAuth → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Default channel for message examples (name or ID)
SLACK_CHANNEL_ID=C0123456789
# Incoming Webhook URL (optional — for simple webhook posting)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
