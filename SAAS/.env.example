# ── PagerDuty ────────────────────────────────────────────────────────────────
# API key: app.pagerduty.com → Integrations → API Access Keys
PAGERDUTY_API_KEY=your_pagerduty_api_key
# Routing key for Events API v2 (service integration key)
PAGERDUTY_ROUTING_KEY=your_32char_integration_key
# Default service ID for incident examples (Services → select service → copy ID from URL)
PAGERDUTY_SERVICE_ID=your_service_id
# Default escalation policy ID
PAGERDUTY_ESCALATION_POLICY_ID=your_escalation_policy_id

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token: api.slack.com → Your Apps → OAuth → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Default channel for message examples (name or ID)
SLACK_CHANNEL_ID=C0123456789
# Incoming Webhook URL (optional — for simple webhook posting)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
